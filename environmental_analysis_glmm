#COLLINEARITY####
#Correlation matrix:
attach(Cordon_Esquel)

names(Cordon_Esquel)

NUMERIC_VARIABLES <- cbind(ALTITUDE,TEMPERATURE,CONDUCTIVITY,OD,POR_OD,
                           PH,TSS,PO4,NH4,NO3NO2)
NUMERIC_VARIABLES

CORRELATION <- cor(NUMERIC_VARIABLES)
CORRELATION

#Correlation matrix graph:
par(mfrow = c(1, 1))
corrplot(CORRELATION)

########################################################################

library(corrplot)

colnames(CORRELATION) <- c(
  "Altitud", "Temperatura", "Conductividad", "OD",
  "% Sat OD", "pH", "TSS", "PO₄",
  "NH₄⁺", "NO₃⁻/NO₂⁻"
)

rownames(CORRELATION) <- colnames(CORRELATION)

# Paleta rojo-negativo, azul-positivo
col_pal <- colorRampPalette(c("red", "white", "blue"))(200)

# --- Capa superior: círculos ---
corrplot(
  CORRELATION,
  method = "circle",
  type = "upper",
  diag = TRUE,                 # diagonal visible (1)
  tl.col = "black",
  tl.cex = 0.8,
  tl.srt = 45,                 # etiquetas en diagonal
  col = col_pal,
  cl.lim = c(-1, 1),
  cl.pos = "r"                 # barra de color a la derecha
)

# --- Capa inferior: números ---
corrplot(
  CORRELATION,
  add = TRUE,
  method = "number",
  type = "lower",
  diag = TRUE,                 # incluye el 1
  number.cex = 0.75,
  number.col = "black",
  tl.pos = "n"
)

######################################################################

#p-values:
TEST <- cor.mtest(CORRELATION)
TEST

